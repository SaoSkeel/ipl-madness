# ─── CricketData.org API (free at cricketdata.org) ───────────────────────────
# Sign up at https://cricketdata.org/member.aspx to get your free API key
CRICKETDATA_API_KEY=your_cricketdata_api_key_here

# IPL 2026 Series ID from CricketData API
# Find it by hitting: https://api.cricapi.com/v1/series?apikey=YOUR_KEY&offset=0
# and searching for "Indian Premier League 2026"
IPL_SERIES_ID=your_ipl_2026_series_id_here

# ─── Firebase (for real-time group sync) ─────────────────────────────────────
# Create a project at https://console.firebase.google.com
# Enable Firestore Database, then go to Project Settings > Service Accounts
# > Generate new private key → download the JSON and paste fields below
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── App Config ───────────────────────────────────────────────────────────────
PORT=3000
ADMIN_PASSWORD=changeme123
# How often to auto-sync results (minutes). Free API: recommend 30. Paid: 5.
SYNC_INTERVAL_MINUTES=30
NODE_ENV=development
